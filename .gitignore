ondevice-pr-timeline/.local/

# local logs
.cursor/
*.log
__pycache__/

# ────────────────────────────────────────────────────────────────
# 모델 가중치 파일 — git에 절대 커밋 금지
# 실제 파일은 T7 SSD 또는 Naver Cloud 보관.
# (2026-04-30 hotfix/remove-lfs-large-files)
# ────────────────────────────────────────────────────────────────

# ONNX
*.onnx
*.onnx.data

# GGUF / llama.cpp
*.gguf

# PyTorch / safetensors
*.bin
*.safetensors
*.pt
*.pth
*.ckpt

# Other inference formats
*.onnx
*.mnn
*.tflite
*.ncnn

# Model directories
models/
weights/
packs/*/model.*
packs/*/tokenizer.*

# Large test fixtures (>1 MB) — CI에서 fetch_test_fixtures.sh로 다운로드
tests/fixtures/large/

# Claude Code 개인 설정
.claude/

# 임시 데이터·캐시
data/raw/
data/cache/
tmp/
*.tmp
*.swp

# 빌드 산출물 (자동 재생성)
dist/

# Python 캐시
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 환경
.env.local
.venv/
venv/
