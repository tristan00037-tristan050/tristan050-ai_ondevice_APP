{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/schemas/capability.schema.json",
  "identifier": "default",
  "description": "Default capability for Butler desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8765/**" },
        { "url": "http://localhost:8765/**" }
      ]
    },
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:scope-download-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-document-recursive"
  ]
}
