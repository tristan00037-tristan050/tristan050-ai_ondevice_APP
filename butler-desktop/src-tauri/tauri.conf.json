{
  "productName": "Butler",
  "version": "0.1.0",
  "identifier": "com.butler.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Butler",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:5903 http://localhost:5903; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/butler-sidecar"],
    "resources": {
      "../../butler_sidecar.py": "butler_sidecar.py",
      "../../butler_pc_core": "butler_pc_core",
      "../../requirements-serving.txt": "requirements-serving.txt"
    }
  }
}
