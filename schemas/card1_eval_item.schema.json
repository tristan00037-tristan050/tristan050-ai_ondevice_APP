{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://butler.example/schemas/card1_eval_item.schema.json",
  "title": "Card1 EvalSet Item",
  "description": "단계 6.5.5 Day 1 — 카드 1 평가 샘플 스키마. raw_text 저장 금지, digest16 보관 원칙 준수.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "text_redacted",
    "raw_digest16",
    "source",
    "intent_type",
    "deadline_type",
    "deadline_is_actionable",
    "slice_tags",
    "action_required",
    "answer_required",
    "auto_apply_allowed",
    "label_status"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "pattern": "^card1_[0-9]{6}$"
    },
    "text": {
      "type": ["string", "null"],
      "description": "synthetic_gold 전용 원문 텍스트. userlog_redacted 는 항상 null."
    },
    "text_redacted": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "userlog_redacted 전용 (PII 치환 후). synthetic_gold 는 null."
    },
    "raw_digest16": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{16}$"
    },
    "source": {
      "type": "string",
      "enum": [
        "synthetic_gold",
        "beta_log_redacted",
        "internal_log_redacted",
        "adjudicated_boundary"
      ]
    },
    "intent_type": {
      "type": "string",
      "enum": ["REQUEST", "COMMAND", "REPORT", "NO_ACTION", "QUESTION"]
    },
    "deadline_type": {
      "type": "string",
      "enum": ["NONE", "HARD", "SOFT", "INQUIRY", "URGENCY", "CONDITION"]
    },
    "deadline_is_actionable": {
      "type": "boolean"
    },
    "slice_tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "action_required": {
      "type": "boolean"
    },
    "answer_required": {
      "type": "boolean"
    },
    "auto_apply_allowed": {
      "type": "boolean"
    },
    "label_status": {
      "type": "string",
      "enum": [
        "draft",
        "double_labeled",
        "adjudicated",
        "approved",
        "gold_reviewed",
        "gold_v1",
        "rejected_pii"
      ]
    },
    "consent_scope": {
      "type": "string"
    },
    "time_expression_redacted": {
      "type": ["string", "null"]
    },
    "risk_tags": {
      "type": "array",
      "uniqueItems": true,
      "default": [],
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "gold": {
      "type": "object"
    },
    "annotator_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "adjudicated": {
      "type": "boolean"
    },
    "annotator_a": { "$ref": "#/$defs/annotatorObject" },
    "annotator_b": { "$ref": "#/$defs/annotatorObject" },
    "reviewer":    { "$ref": "#/$defs/reviewerObject" },
    "adjudicator": { "$ref": "#/$defs/reviewerObject" },
    "final_gold":  { "$ref": "#/$defs/finalGoldObject" },
    "auto_apply_reasoning": { "$ref": "#/$defs/autoApplyReasoningObject" }
  },
  "$defs": {
    "annotatorObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "intent_type", "deadline_type", "auto_apply_allowed", "labeled_at"],
      "properties": {
        "id":                 { "type": "string" },
        "intent_type":        { "enum": ["REQUEST","COMMAND","REPORT","NO_ACTION","QUESTION"] },
        "deadline_type":      { "enum": ["NONE","HARD","SOFT","INQUIRY","URGENCY","CONDITION"] },
        "auto_apply_allowed": { "type": "boolean" },
        "labeled_at":         { "type": "string" }
      }
    },
    "reviewerObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "decision", "reviewed_at"],
      "properties": {
        "id":          { "type": "string" },
        "decision":    { "enum": ["approved", "rejected", "needs_revision"] },
        "reviewed_at": { "type": "string" }
      }
    },
    "finalGoldObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent_type", "deadline_type", "auto_apply_allowed", "finalized_at"],
      "properties": {
        "intent_type":   { "enum": ["REQUEST","COMMAND","REPORT","NO_ACTION","QUESTION"] },
        "deadline_type": { "enum": ["NONE","HARD","SOFT","INQUIRY","URGENCY","CONDITION"] },
        "auto_apply_allowed":     { "type": "boolean" },
        "deadline":               { "type": ["object", "null"] },
        "actions":                { "type": "array" },
        "materials":              { "type": "array" },
        "finalized_at":           { "type": "string" },
        "disagreement_resolution":{ "type": "string" }
      }
    },
    "autoApplyReasoningObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_basis", "verifier_pass", "explanation"],
      "properties": {
        "evidence_basis": { "type": "string", "minLength": 1 },
        "verifier_pass":  { "type": "boolean" },
        "explanation":    { "type": "string", "minLength": 10 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source": {
            "enum": ["internal_log_redacted", "beta_log_redacted", "adjudicated_boundary"]
          }
        },
        "required": ["source"]
      },
      "then": {
        "properties": {
          "text":          { "type": "null" },
          "text_redacted": { "type": "string", "minLength": 1 }
        },
        "required": ["text_redacted"]
      }
    },
    {
      "if": {
        "properties": {
          "source": { "const": "synthetic_gold" }
        },
        "required": ["source"]
      },
      "then": {
        "properties": {
          "text": { "type": "string", "minLength": 1 }
        },
        "required": ["text"]
      }
    },
    {
      "if": {
        "properties": { "label_status": { "const": "double_labeled" } },
        "required":   ["label_status"]
      },
      "then": {
        "required": ["annotator_a", "annotator_b"]
      }
    },
    {
      "if": {
        "properties": {
          "label_status": { "enum": ["approved", "gold_reviewed", "gold_v1"] }
        },
        "required": ["label_status"]
      },
      "then": {
        "required": ["reviewer"]
      }
    },
    {
      "if": {
        "properties": { "label_status": { "const": "adjudicated" } },
        "required":   ["label_status"]
      },
      "then": {
        "required": ["adjudicator", "final_gold"]
      }
    },
    {
      "if": {
        "properties": { "label_status": { "const": "gold_v1" } },
        "required":   ["label_status"]
      },
      "then": {
        "required": ["adjudicator", "final_gold", "reviewer"]
      }
    },
    {
      "if": {
        "properties": { "auto_apply_allowed": { "const": true } },
        "required":   ["auto_apply_allowed"]
      },
      "then": {
        "required": ["auto_apply_reasoning"]
      }
    }
  ]
}
