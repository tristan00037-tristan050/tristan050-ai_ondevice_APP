{
  "description": "tool_call strict validator fixture — schema_v3 기준 통과/실패 케이스",
  "schema_version": "v3",
  "pass_cases": [
    {
      "tool_name": "get_weather",
      "arguments": {"location": "서울", "date": "2026-03-16"}
    },
    {
      "tool_name": "get_weather",
      "arguments": {"location": "New York", "unit": "fahrenheit"}
    },
    {
      "tool_name": "set_volume",
      "arguments": {"level": 50}
    },
    {
      "tool_name": "set_volume",
      "arguments": {"level": 0}
    },
    {
      "tool_name": "toggle_wifi",
      "arguments": {"enabled": true}
    },
    {
      "tool_name": "toggle_wifi",
      "arguments": {"enabled": false, "network_name": "OfficeNet"}
    },
    {
      "tool_name": "add_schedule",
      "arguments": {"title": "팀 회의", "date": "2026-03-17"}
    },
    {
      "tool_name": "add_schedule",
      "arguments": {"title": "고객 미팅", "date": "2026-03-18", "time": "14:00", "location": "3층 회의실"}
    },
    {
      "tool_name": "send_email",
      "arguments": {"to": ["alice@company.com"], "subject": "보고서 공유", "body": "첨부 파일 확인 부탁드립니다."}
    },
    {
      "tool_name": "search_contact",
      "arguments": {"query": "김철수"}
    },
    {
      "tool_name": "search_contact",
      "arguments": {"query": "Engineering", "department": "개발팀", "limit": 20}
    },
    {
      "tool_name": "summarize_doc",
      "arguments": {"content": "이 문서는 분기 보고서입니다.", "max_length": 300, "language": "ko"}
    },
    {
      "tool_name": "open_file",
      "arguments": {"filename": "Q1_report.pdf"}
    },
    {
      "tool_name": "save_memo",
      "arguments": {"content": "회의에서 논의된 주요 사항", "title": "3월 팀 회의", "tags": ["회의", "3월"]}
    }
  ],
  "fail_cases": [
    {
      "case": "unregistered_tool",
      "tool_name": "send_message",
      "arguments": {"to": "홍길동", "content": "안녕하세요"},
      "expect_fail_reason": "unregistered tool_name"
    },
    {
      "case": "unregistered_tool_2",
      "tool_name": "get_schedule",
      "arguments": {"date": "2026-03-17"},
      "expect_fail_reason": "unregistered tool_name (v3에서 제거됨)"
    },
    {
      "case": "missing_required",
      "tool_name": "get_weather",
      "arguments": {},
      "expect_fail_reason": "missing required: location"
    },
    {
      "case": "missing_required_multiple",
      "tool_name": "send_email",
      "arguments": {"to": ["x@y.com"]},
      "expect_fail_reason": "missing required: subject, body"
    },
    {
      "case": "empty_string",
      "tool_name": "get_weather",
      "arguments": {"location": ""},
      "expect_fail_reason": "empty string not allowed"
    },
    {
      "case": "empty_string_2",
      "tool_name": "save_memo",
      "arguments": {"content": "   "},
      "expect_fail_reason": "empty string not allowed (공백만 있음)"
    },
    {
      "case": "wrong_type_integer_expected",
      "tool_name": "set_volume",
      "arguments": {"level": "크게"},
      "expect_fail_reason": "expected integer, got str"
    },
    {
      "case": "bool_as_integer",
      "tool_name": "set_volume",
      "arguments": {"level": true},
      "expect_fail_reason": "expected integer, got bool"
    },
    {
      "case": "wrong_type_array_expected",
      "tool_name": "send_email",
      "arguments": {"to": "alice@company.com", "subject": "s", "body": "b"},
      "expect_fail_reason": "to: expected array, got str"
    },
    {
      "case": "range_violation_max",
      "tool_name": "set_volume",
      "arguments": {"level": 150},
      "expect_fail_reason": "level: 150 > maximum 100"
    },
    {
      "case": "range_violation_min",
      "tool_name": "set_volume",
      "arguments": {"level": -1},
      "expect_fail_reason": "level: -1 < minimum 0"
    },
    {
      "case": "enum_violation",
      "tool_name": "get_weather",
      "arguments": {"location": "서울", "unit": "kelvin"},
      "expect_fail_reason": "unit: 'kelvin' not in enum ['celsius', 'fahrenheit']"
    },
    {
      "case": "extra_key",
      "tool_name": "get_weather",
      "arguments": {"location": "서울", "UNKNOWN_FIELD": "x"},
      "expect_fail_reason": "extra keys: ['UNKNOWN_FIELD']"
    },
    {
      "case": "range_limit_search_contact",
      "tool_name": "search_contact",
      "arguments": {"query": "팀", "limit": 0},
      "expect_fail_reason": "limit: 0 < minimum 1"
    }
  ]
}
